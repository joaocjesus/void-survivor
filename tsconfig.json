{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ES2022",
        "moduleResolution": "Bundler",
        "strict": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "types": [
            "vite/client",
            "vitest"
        ],
        "rootDir": "src",
        "outDir": "dist"
    },
    "include": [
        "src"
    ],
    "references": []
}
